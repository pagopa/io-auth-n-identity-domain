{
  "name": "io-session-manager-oi",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/main.js",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsc",
    "build:watch": "tsc -w",
    "typecheck": "tsc --noemit",
    "lint": "pnpm lint:check --fix",
    "lint:check": "eslint .",
    "start": "node dist/main.js",
    "test": "vitest run -c ./vite.config.mts",
    "test:integration": "vitest run -c ./src/__integrations__/vite.config.mts",
    "test:coverage": "vitest run --coverage -c ./vite.config.mts",
    "generate": "pnpm generate:io-profile-client",
    "generate:io-profile-client": "openapi-ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "catalog:",
    "@azure/core-client": "catalog:",
    "@azure/cosmos": "catalog:",
    "@azure/data-tables": "catalog:",
    "@azure/identity": "catalog:",
    "@pagopa/azure-sdk": "workspace:^",
    "@pagopa/hexagonal-core": "catalog:",
    "@pagopa/hexagonal-fastify": "catalog:",
    "@pagopa/io-auth-n-identity-domain": "workspace:^",
    "@pagopa/io-env-config": "workspace:^",
    "@pagopa/io-package-info": "workspace:^",
    "dotenv": "catalog:",
    "fastify": "catalog:",
    "neverthrow": "catalog:",
    "range_check": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pagopa/typescript-config-node22": "workspace:^",
    "@hey-api/openapi-ts": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-config-monorepo": "workspace:^",
    "shx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
