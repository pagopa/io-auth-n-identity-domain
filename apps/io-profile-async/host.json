{
  "version": "2.0",
  "logging": {
    "logLevel": {
      "default": "Information",
      "Function": "Warning",
      "Microsoft.Azure.ServiceBus": "Warning",
      "Azure.Messaging.ServiceBus": "Warning",
      "Microsoft.Azure.WebJobs.ServiceBus.Listeners.ServiceBusListener": "Warning"
    }
  },
  "extensions": {
    "http": {
      "routePrefix": ""
    },
    "queues": {
      "maxDequeueCount": 10,
      "maxPollingInterval": "00:00:02",
      "visibilityTimeout": "00:02:00",
      "batchSize": 16,
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.0.0, 5.0.0)"
  }
}
